@baseUrl = http://localhost:3000
@email = testuser@example.com
@password = password123

### 1. Register a New User
# @name signUp
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

###

### 2. Login User
# @name signIn
POST {{baseUrl}}/auth/signin
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Save Token Variable (Use VS Code Rest Client style variables)
@authToken = {{signIn.response.body.access_token}}

###

### 3. Get Current User Profile (Requires JWT)
GET {{baseUrl}}/auth/profile
Authorization: Bearer {{authToken}}

###

### 4. Get All Users (Requires JWT)
GET {{baseUrl}}/users
Authorization: Bearer {{authToken}}

###

### 5. Get User by ID (Requires JWT)
# Replace '1' with the correct user ID from the signup/users list
GET {{baseUrl}}/users/1
Authorization: Bearer {{authToken}}

###

### 6. Update User (Requires JWT)
# Replace '1' with the correct user ID
PATCH {{baseUrl}}/users/1
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "email": "testuser-updated@example.com",
  "password": "newpassword123"
}

###

### 7. Delete User (Requires JWT)
# Replace '1' with the correct user ID
DELETE {{baseUrl}}/users/1
Authorization: Bearer {{authToken}}
